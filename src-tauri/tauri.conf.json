{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simon Says",
  "version": "1.0.1",
  "identifier": "com.kbosompem.simonsays",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Simon Says",
        "width": 1120,
        "height": 820,
        "minWidth": 780,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Friendly YouTube downloader (yt-dlp + ffmpeg).",
    "longDescription": "Simon Says is a friendly desktop front-end for yt-dlp and ffmpeg. Paste a YouTube link, pick your resolution, format and subtitle tracks, and queue up downloads — no command line required."
  }
}
